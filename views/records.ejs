<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>血壓記錄<%= typeof userName !== 'undefined' && userName ? ' (' + userName + ')' : '' %><%= typeof titleSuffix !== 'undefined' && titleSuffix && !userName ? ' (' + titleSuffix + ')' : '' %></title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#2d6a4f">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <!-- 頂部導航 -->
        <div class="top-nav">
            <a href="/" class="nav-btn">← 返回</a>
            <h1>血壓記錄<%= typeof userName !== 'undefined' && userName ? ' (' + userName + ')' : '' %></h1>
            <a href="/export/excel?userId=<%= userId %>&name=<%= encodeURIComponent(typeof userName !== 'undefined' ? userName : '') %>" class="nav-btn" style="font-size:15px;">📥 匯出</a>
        </div>

        <%
            var userId = typeof userId !== 'undefined' ? userId : 1;
            // 取得所有月份並排序
            var months = Object.keys(groupedRecords).sort();
            var currentIdx = months.indexOf(selectedMonth);
            if (currentIdx === -1) currentIdx = months.length - 1;
            var currentMonth = months.length > 0 ? months[currentIdx] : null;
            var prevMonth = currentIdx > 0 ? months[currentIdx - 1] : null;
            var nextMonth = currentIdx < months.length - 1 ? months[currentIdx + 1] : null;

            // 格式化月份顯示
            function formatMonth(ym) {
                return ym ? ym.replace('-', '年') + '月' : '';
            }
        %>

        <% if (currentMonth) { %>
        <!-- 月份導航 -->
        <div class="month-nav">
            <% if (prevMonth) { %>
                <a href="/records?yearMonth=<%= prevMonth %>&userId=<%= userId %>&name=<%= encodeURIComponent(typeof userName !== 'undefined' ? userName : '') %>" class="arrow-btn">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </a>
            <% } else { %>
                <span class="arrow-btn" style="visibility:hidden;">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </span>
            <% } %>
            <select class="month-select" onchange="location=this.value">
                <% months.forEach(function(m) { %>
                    <option value="/records?yearMonth=<%= m %>&userId=<%= userId %>&name=<%= encodeURIComponent(typeof userName !== 'undefined' ? userName : '') %>" <%= m === currentMonth ? 'selected' : '' %>><%= formatMonth(m) %></option>
                <% }); %>
            </select>
            <% if (nextMonth) { %>
                <a href="/records?yearMonth=<%= nextMonth %>&userId=<%= userId %>&name=<%= encodeURIComponent(typeof userName !== 'undefined' ? userName : '') %>" class="arrow-btn">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
            <% } else { %>
                <span class="arrow-btn" style="visibility:hidden;">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </span>
            <% } %>
        </div>
        <% } %>

        <!-- 記錄卡片列表 -->
        <% if (groupedRecords[currentMonth] && groupedRecords[currentMonth].length) { %>
            <% groupedRecords[currentMonth].forEach(function(record) {
                var hp = parseInt(record.high_pressure);
                var lp = parseInt(record.low_pressure);
                var borderClass = '';
                if (hp >= 140 || lp >= 90) {
                    borderClass = 'bp-high-border';
                } else {
                    borderClass = 'bp-normal-border';
                }
            %>
                <div class="record-card <%= borderClass %>">
                    <div class="card-header">
                        <span><%= record.formattedDate %></span>
                    </div>
                    <div class="card-body">
                        <div class="card-metric">
                            <span class="metric-value"><%= record.high_pressure %></span>
                            <span class="metric-label">高壓</span>
                        </div>
                        <div class="card-metric">
                            <span class="metric-value"><%= record.low_pressure %></span>
                            <span class="metric-label">低壓</span>
                        </div>
                        <div class="card-metric">
                            <span class="metric-value"><%= record.heartbeat %></span>
                            <span class="metric-label">心跳</span>
                        </div>
                    </div>
                    <div class="card-actions">
                        <a href="/modify/<%= record.id %>?userId=<%= userId %>" class="btn btn-secondary">修改</a>
                        <form action="/delete/<%= record.id %>" method="POST" style="display:inline;"
                              onsubmit="return confirm('確定要刪除這條記錄嗎？');">
                            <button type="submit" class="btn btn-danger">刪除</button>
                        </form>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="empty-state">
                沒有記錄
            </div>
        <% } %>
    </div>
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js');
        }
    </script>
</body>
</html>
