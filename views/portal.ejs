<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>血壓紀錄管理系統<%= typeof titleSuffix !== 'undefined' && titleSuffix ? ' (' + titleSuffix + ')' : '' %></title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#2d6a4f">
    <link rel="stylesheet" href="/styles.css">
    <style>
        body{background:linear-gradient(135deg,#f0f4f8 0,#e8f5e9 100%);min-height:100vh}
        .portal-wrap{width:100%;max-width:560px;margin:0 auto;padding:20px 16px;min-height:100vh;display:flex;flex-direction:column}
        .portal-header{background:linear-gradient(135deg,#2d6a4f,#40916c);color:#fff;border-radius:24px;padding:28px;text-align:center;margin-bottom:32px;box-shadow:0 8px 24px rgba(45,106,79,0.25)}
        .portal-header h1{font-size:30px;font-weight:700;margin-bottom:6px;color:#fff}
        .portal-header p{font-size:17px;opacity:.85;margin:0}
        .user-grid{display:flex;flex-wrap:wrap;gap:20px;justify-content:center;padding:20px 0;flex:1;align-content:center;align-items:center}
        .user-card{display:flex;flex-direction:column;align-items:center;text-decoration:none;width:130px;padding:20px 16px 18px;border-radius:20px;background:#fff;box-shadow:0 4px 16px rgba(0,0,0,0.06);transition:all .25s ease;cursor:pointer}
        .user-card:hover{transform:translateY(-6px);box-shadow:0 12px 32px rgba(0,0,0,0.12);background:#fff}
        .user-avatar{width:88px;height:88px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:38px;color:#fff;margin-bottom:14px;box-shadow:0 6px 16px rgba(0,0,0,0.18);transition:transform .25s ease;font-weight:600}
        .user-card:hover .user-avatar{transform:scale(1.08)}
        .user-name{font-size:22px;font-weight:700;color:#1a1a2e}
        .admin-link{position:fixed;bottom:24px;right:24px;width:52px;height:52px;border-radius:50%;background:#2d6a4f;color:#fff;border:none;font-size:24px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(45,106,79,0.3);text-decoration:none;z-index:10;transition:transform .2s}
        .admin-link:hover{transform:scale(1.1)}
        @media(max-width:480px){.portal-header{padding:20px 16px;margin-bottom:24px}.portal-header h1{font-size:24px}.user-card{width:110px;padding:16px 12px}.user-avatar{width:72px;height:72px;font-size:32px}.user-name{font-size:19px}}
    </style>
</head>
<body>
    <div class="portal-wrap">
        <div class="portal-header">
            <h1>🏠 血壓紀錄管理系統</h1>
            <p>選擇使用者開始記錄</p>
        </div>

        <div class="user-grid">
            <% users.forEach(function(u) { %>
                <a href="/bp/<%= u.id %>?name=<%= encodeURIComponent(u.name) %>" class="user-card" onclick="localStorage.setItem('bp_user', '<%= u.id %>')">
                    <div class="user-avatar" style="background:<%= u.color %>">
                        <%= u.name.charAt(0) %>
                    </div>
                    <span class="user-name"><%= u.name %></span>
                </a>
            <% }); %>
        </div>
    </div>

    <a href="/admin" class="admin-link">⚙</a>

    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js');
        }
    </script>
</body>
</html>
